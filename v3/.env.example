# Despliegue sin Docker: coloca este archivo .env junto a config.php
# (si subes solo el contenido de app, este .env debe ir en esa misma carpeta)
# Configuración de Base de Datos
DB_HOST=localhost
DB_PORT=3306
DB_USER=app_user
DB_PASSWORD=app_pass
DB_NAME=registros_tareas
DB_ROOT_PASSWORD=root_pass

# Configuración del Servidor Web
WEB_PORT=8081

